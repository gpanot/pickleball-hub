# PostgreSQL connection string
# For local development: postgresql://user:password@localhost:5432/pickleball_hub
# For Railway: get from Railway dashboard > Variables > DATABASE_URL
DATABASE_URL="postgresql://user:password@localhost:5432/pickleball_hub?schema=public"

# Optional: POST /api/admin/trigger-scraper (Next.js) redeploys the Railway scraper without waiting for cron.
# SCRAPER_TRIGGER_SECRET=long-random-string
# RAILWAY_API_TOKEN=from https://railway.com/account/tokens (account or workspace token)
# RAILWAY_ENVIRONMENT_ID=from Railway dashboard (Cmd+K copy environment id)
# RAILWAY_SCRAPER_SERVICE_ID=scraper service id in the same project

# Microsoft Clarity (session replay / heatmaps). Set in Vercel env for production.
NEXT_PUBLIC_CLARITY_PROJECT_ID=wgp2gzo0w2

# POST /api/revalidate — same secret on Vercel (web) and Railway (scraper).
# Generate a long random string; curl: POST ... -H "x-revalidate-token: <secret>"
# REVALIDATE_SECRET=

# Railway scraper only: production app URL (no trailing slash). Used after successful ingest.
# VERCEL_APP_URL=https://your-app.vercel.app
