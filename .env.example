# PostgreSQL connection string
# For local development: postgresql://user:password@localhost:5432/pickleball_hub
# For Railway: get from Railway dashboard > Variables > DATABASE_URL
DATABASE_URL="postgresql://user:password@localhost:5432/pickleball_hub?sslmode=disable"

# --- Use production (live) data while running `npm run dev` locally ---
# Next.js loads `.env.local` after `.env` and overrides variables — so you can
# keep localhost in `.env` and only override the DB in `.env.local`:
#
#   1. Copy DATABASE_URL from production (same DB the live site uses):
#      Railway: Project → your Postgres service → Variables / Connect, or
#      Project → Variables if DATABASE_URL is set at project level.
#      Vercel: only if you store DATABASE_URL there for reference.
#   2. Create `pickleball-hub/.env.local` (git-ignored) with one line:
#        DATABASE_URL="postgresql://...paste exact connection string..."
#   3. Restart `npm run dev`. Prisma reads DATABASE_URL from the environment.
#
# Mobile dev sign-in as your real account (local DB only):
#   DEV_IMPERSONATE_EMAIL=you@example.com
#   npx tsx scripts/sync-dev-account-from-prod.ts you@example.com
#
# Safety: this points read/write at production. Do not run migrations or
# destructive scripts against that URL.

# Migrations are managed by dbmate (see CONTRIBUTING.md). To apply locally:
#   npm run db:migrate
# To apply against a specific URL one-shot:
#   DATABASE_URL="postgresql://USER:PASS@localhost:5432/pickleball_hub?sslmode=disable" dbmate up

# --- Railway: scraper DB vs app DB (important) ---
# The **scraper** service `DATABASE_URL` often points at a small Postgres used only
# by `ingest.py` (psycopg2). That DB may have **no** `schema_migrations` table —
# tables were created by raw SQL. Your **Vercel** app should use the same DB you
# migrate with dbmate, OR apply new DDL to the scraper DB separately
# (run the relevant `db/migrations/*.sql` files against that URL).
# Scripts that merge `.env` + `.env.local` hit **.env.local last** — a probe for
# `players` / `session_rosters` using the merged URL checks **that** DB, not localhost.

# Optional: POST /api/admin/trigger-scraper (Next.js) redeploys the Railway scraper without waiting for cron.
# SCRAPER_TRIGGER_SECRET=long-random-string
# RAILWAY_API_TOKEN=from https://railway.com/account/tokens (account or workspace token)
# RAILWAY_ENVIRONMENT_ID=from Railway dashboard (Cmd+K copy environment id)
# RAILWAY_SCRAPER_SERVICE_ID=scraper service id in the same project

# Mouseflow session replay (optional — layout defaults to the project UUID from your snippet).
# NEXT_PUBLIC_MOUSEFLOW_PROJECT_ID=c05d4709-4143-4a9b-b914-0aa21a9f2bdf

# POST /api/revalidate — same secret on Vercel (web) and Railway (scraper).
# Generate a long random string; curl: POST ... -H "x-revalidate-token: <secret>"
# REVALIDATE_SECRET=

# Railway scraper → Railway mobile API for push crons (PN6/PN7). Vercel is web-only.
# Set on the **scraper** service in Railway (same CRON_SECRET as mobile API):
# MOBILE_API_URL=https://pickleball-hub-mobile-i9ag-production.up.railway.app
#
# Vercel (web only): cache revalidation after ingest — not used for push notifications.
# VERCEL_APP_URL=https://hub.thecourtflow.com

# Vercel Web Analytics (@vercel/analytics in app/layout.tsx): Vercel dashboard → your project → Analytics → Enable. Redeploy after enabling.

# Optional: `next build` — how many /sessions/[referenceCode] pages to pre-generate (default 40). Lower if build hits "too many database connections".
# STATIC_SESSION_DETAIL_MAX=40

# --- NextAuth (Google Login) ---
# Generate AUTH_SECRET with: npx auth secret  OR  openssl rand -base64 32
# Must be set on Vercel/Railway production environment too.
# AUTH_SECRET=
# NEXTAUTH_URL=https://your-app.vercel.app   # required on Vercel prod (not needed on Railway)
# GOOGLE_CLIENT_ID=                          # from Google Cloud Console OAuth 2.0 credentials
# GOOGLE_CLIENT_SECRET=                      # from Google Cloud Console OAuth 2.0 credentials
# AUTH_GOOGLE_ID=                            # same as GOOGLE_CLIENT_ID (NextAuth v5 beta alias)
# AUTH_GOOGLE_SECRET=                        # same as GOOGLE_CLIENT_SECRET (NextAuth v5 beta alias)

# --- Google Maps / Places API (pickleball venue search) ---
# Server-side key for API routes. Restrict in Google Cloud: API restrictions → Places API (New).
# Application restrictions → IP addresses (Railway/Vercel), not Android/iOS.
# GOOGLE_MAPS_API_KEY=

# --- Firebase Admin (push notifications) — Railway mobile API production ---
# Paste the entire service account JSON as one line (see push-notifications.md).
# Set on **pickleball-hub-mobile** Railway service (not Vercel — Vercel is web-only).
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"...","private_key":"-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n","client_email":"...@....iam.gserviceaccount.com",...}
