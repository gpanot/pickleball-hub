generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Club {
  id          Int       @id @default(autoincrement())
  reclubId    Int       @unique @map("reclub_id")
  name        String
  slug        String    @unique
  sportId     Int?      @map("sport_id")
  communityId Int?      @map("community_id")
  /// Market identifier — 'hcm' (Ho Chi Minh City) | 'kl' (Kuala Lumpur). Used to isolate data between regions.
  market      String    @default("hcm")
  numMembers  Int       @default(0) @map("num_members")
  zaloUrl     String?   @map("zalo_url")
  phone       String?
  admins      String[]  @default([])
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  sessions    Session[]
  dailyStats  ClubDailyStat[]
  accessCodes AccessCode[]

  @@map("clubs")
}

model Venue {
  id        Int       @id @default(autoincrement())
  name      String
  address   String
  latitude  Float
  longitude Float
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")

  sessions      Session[]
  accessCodes   AccessCode[]
  radarSessions RadarSession[]
  cardBattles   CardBattle[]
  venueInfTotals  VenueInfTotal[]
  pulseCooldowns  VenuePulseCooldown[]
  clubSessions  ClubSession[]

  @@index([latitude, longitude])
  @@map("venues")
}

model Session {
  id             Int       @id @default(autoincrement())
  referenceCode  String    @map("reference_code")
  name           String
  clubId         Int       @map("club_id")
  venueId        Int?      @map("venue_id")
  startTime      String    @map("start_time")
  endTime        String    @map("end_time")
  durationMin    Int       @map("duration_min")
  maxPlayers     Int       @map("max_players")
  feeAmount      Int       @default(0) @map("fee_amount")
  feeCurrency    String    @default("VND") @map("fee_currency")
  costPerHour    Float?    @map("cost_per_hour")
  privacy        String    @default("public")
  status         String    @default("active")
  skillLevelMin  Float?    @map("skill_level_min")
  skillLevelMax  Float?    @map("skill_level_max")
  perks          String[]  @default([])
  /// Reclub event notes / description (plain text)
  description    String?   @map("description")
  eventUrl       String    @map("event_url")
  scrapedDate    String    @map("scraped_date")

  club           Club      @relation(fields: [clubId], references: [id])
  venue          Venue?    @relation(fields: [venueId], references: [id])
  snapshots      DailySnapshot[]
  rosters        SessionRoster[]
  duprStat       SessionDuprStat?

  @@unique([referenceCode, scrapedDate])
  @@index([scrapedDate])
  @@index([clubId])
  @@index([venueId])
  @@index([startTime])
  @@index([scrapedDate, status, startTime])
  @@map("sessions")
}

model DailySnapshot {
  id         Int      @id @default(autoincrement())
  sessionId  Int      @map("session_id")
  scrapedAt  DateTime @default(now()) @map("scraped_at")
  joined     Int      @default(0)
  waitlisted Int      @default(0)

  session    Session  @relation(fields: [sessionId], references: [id])

  @@index([sessionId])
  @@index([scrapedAt])
  @@map("daily_snapshots")
}

model AccessCode {
  id         Int       @id @default(autoincrement())
  code       String    @unique
  entityType String    @map("entity_type")
  clubId     Int?      @map("club_id")
  venueId    Int?      @map("venue_id")
  label      String
  createdAt  DateTime  @default(now()) @map("created_at")
  expiresAt  DateTime? @map("expires_at")

  club       Club?     @relation(fields: [clubId], references: [id])
  venue      Venue?    @relation(fields: [venueId], references: [id])

  @@map("access_codes")
}

model ClubDailyStat {
  id             Int      @id @default(autoincrement())
  clubId         Int      @map("club_id")
  date           String
  totalSessions  Int      @default(0) @map("total_sessions")
  totalCapacity  Int      @default(0) @map("total_capacity")
  totalJoined    Int      @default(0) @map("total_joined")
  avgFillRate    Float    @default(0) @map("avg_fill_rate")
  avgFee         Float    @default(0) @map("avg_fee")
  revenueEstimate Float   @default(0) @map("revenue_estimate")

  club           Club     @relation(fields: [clubId], references: [id])

  @@unique([clubId, date])
  @@index([date])
  @@map("club_daily_stats")
}

/// HCM-wide median session cost/hour (VND) for a calendar day — used for scoring and market trend charts.
model HcmMarketMedianDaily {
  date              String   @id @map("date")
  medianCostPerHour Float    @map("median_cost_per_hour")
  updatedAt         DateTime @updatedAt @map("updated_at")

  @@map("hcm_market_median_daily")
}

/// Reclub user; DUPR fields from /players/userIds when roster scrape runs.
model Player {
  userId                   BigInt    @id @map("user_id")
  username                 String?
  displayName              String?   @map("display_name")
  imageUrl                 String?   @map("image_url")
  duprSingles              Decimal?  @map("dupr_singles") @db.Decimal(5, 3)
  duprDoubles              Decimal?  @map("dupr_doubles") @db.Decimal(5, 3)
  duprSinglesReliability   Int?      @map("dupr_singles_reliability")
  duprDoublesReliability   Int?      @map("dupr_doubles_reliability")
  duprId                   String?   @map("dupr_id")
  duprUpdatedAt            DateTime? @map("dupr_updated_at")
  lastSeenAt               DateTime? @map("last_seen_at")
  createdAt                DateTime  @default(now()) @map("created_at")
  updatedAt                DateTime  @updatedAt @map("updated_at")

  rosters     SessionRoster[]
  followers   Follow[]              @relation("followers")
  profile     PlayerProfile?
  duprHistory PlayerDuprHistory[]

  @@map("players")
}

model PlayerDuprHistory {
  id          Int      @id @default(autoincrement())
  playerId    BigInt   @map("player_id")
  duprDoubles Decimal? @map("dupr_doubles") @db.Decimal(5, 3)
  recordedAt  DateTime @default(now()) @map("recorded_at")
  source      String   @default("scraper")

  player Player @relation(fields: [playerId], references: [userId], onDelete: Cascade)

  @@index([playerId, recordedAt])
  @@map("player_dupr_history")
}

/// One row per session per user (confirmed roster from Nuxt scrape).
model SessionRoster {
  id          Int      @id @default(autoincrement())
  sessionId   Int      @map("session_id")
  userId      BigInt   @map("user_id")
  isHost      Boolean  @default(false) @map("is_host")
  isConfirmed Boolean  @default(true) @map("is_confirmed")
  scrapedAt   DateTime @default(now()) @map("scraped_at")
  firstSeenAt DateTime @default(now()) @map("first_seen_at")

  session Session @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  player  Player  @relation(fields: [userId], references: [userId], onDelete: Cascade)

  @@unique([sessionId, userId])
  @@index([sessionId])
  @@index([userId])
  @@map("session_rosters")
}

/// Anonymous or Zalo-identified player profile for personalised recommendations.
/// After Google login, userId is linked to the NextAuth User record.
model PlayerProfile {
  id                    String    @id @default(uuid())
  userId                String?   @unique @map("user_id")
  zaloId                String?   @unique @map("zalo_id")
  reclubUserId          BigInt?   @unique @map("reclub_user_id")
  displayName           String?   @map("display_name")
  gender                String?
  preferences           Json      @default("{}")
  onboardingCompleted   Boolean   @default(false) @map("onboarding_completed")
  welcomeChestClaimed   Boolean   @default(false) @map("welcome_chest_claimed")
  pushToken             String?   @map("push_token")
  pushTokenIos          String?   @map("push_token_ios")
  pushTokenUpdatedAt    DateTime? @map("push_token_updated_at")
  lastActiveAt          DateTime? @map("last_active_at")
  streakData            Json?     @map("streak_data")
  streakComputedAt      DateTime? @map("streak_computed_at")
  squadNickname         String?   @unique @map("squad_nickname")
  squadNicknameSetAt    DateTime? @map("squad_nickname_set_at")
  reportFlaggedAt       DateTime? @map("report_flagged_at")
  suspended             Boolean   @default(false)
  banned                Boolean   @default(false)
  createdAt             DateTime  @default(now()) @map("created_at")
  lastSeen              DateTime  @updatedAt @map("last_seen")

  user         User?    @relation(fields: [userId], references: [id])
  reclubPlayer Player?  @relation(fields: [reclubUserId], references: [userId])
  following    Follow[] @relation("following")
  notificationsReceived NotificationSent[] @relation("recipient")
  notificationsSent     NotificationSent[] @relation("sender")
  gear         PlayerGear?
  feedItems    FeedItem[]
  playIntent        PlayIntent?
  blocking          Block[]   @relation("Blocker")
  blockedBy         Block[]   @relation("Blocked")
  reportsMade       Report[]  @relation("Reporter")
  reportsReceived   Report[]  @relation("Reported")
  foundedSquads     Squad[]       @relation("SquadFounder")
  squadMemberships  SquadMember[]
  sentInvites       SquadInvite[] @relation("InviterInvites")
  chestsEarned      SquadChest[]       @relation("ChestEarner")
  chestOpenings     SquadChestOpening[]
  radarSessions    RadarSession[]
  pulseCooldowns   VenuePulseCooldown[]
  squadAlerts      SquadAlert[]
  podMemberships   PodMember[]
  foundedPods      Pod[]         @relation("PodFounder")
  brand            PlayerBrand?
  wallet           PlayerWallet?
  // Club Sessions relations
  foundedAppClubs       AppClub[]           @relation("AppClubCreator")
  appClubManagerRoles   AppClubManager[]    @relation("ManagerProfile")
  appClubManagersAdded  AppClubManager[]    @relation("ManagerAddedBy")
  hostedSessions        ClubSession[]       @relation("SessionHost")
  clubSessionBookings   ClubSessionBooking[]
  appClubMemberships    AppClubMember[]

  @@map("player_profiles")
}

model PlayerGear {
  id                String    @id @default(cuid())
  profileId         String    @unique @map("profile_id")
  cap               String?
  shirt             String?
  paddle            String?
  shoes             String?
  setupCompletedAt  DateTime? @map("setup_completed_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")

  profile    PlayerProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@map("player_gear")
}

/// Social graph: an app user (PlayerProfile) follows a Reclub player.
model Follow {
  id         Int      @id @default(autoincrement())
  followerId String   @map("follower_id")
  followeeId BigInt   @map("followee_id")
  createdAt  DateTime @default(now()) @map("created_at")

  follower   PlayerProfile @relation("following", fields: [followerId], references: [id], onDelete: Cascade)
  followee   Player        @relation("followers", fields: [followeeId], references: [userId], onDelete: Cascade)

  @@unique([followerId, followeeId])
  @@index([followerId])
  @@index([followeeId])
  @@map("follows")
}

// ── NextAuth.js v5 required models ────────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime? @map("email_verified")
  image         String?
  accounts      Account[]
  sessions      AuthSession[]
  profile       PlayerProfile?

  @@map("auth_users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String  @map("user_id")
  type              String
  provider          String
  providerAccountId String  @map("provider_account_id")
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("auth_accounts")
}

model AuthSession {
  id           String   @id @default(cuid())
  sessionToken String   @unique @map("session_token")
  userId       String   @map("user_id")
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("auth_sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("auth_verification_tokens")
}

model AdminSettings {
  id                String   @id @default("singleton")
  llmModel          String   @default("claude-haiku-4-5-20251001") @map("llm_model")
  temperature       Float    @default(0.7)
  maxTokens         Int      @default(1000) @map("max_tokens")
  monthlyBudgetUsd  Float    @default(5.00) @map("monthly_budget_usd")
  updatedAt         DateTime @updatedAt @map("updated_at")

  @@map("admin_settings")
}

model LlmUsageLog {
  id           String   @id @default(uuid())
  model        String
  inputTokens  Int      @map("input_tokens")
  outputTokens Int      @map("output_tokens")
  costUsd      Float    @map("cost_usd")
  postType     String   @map("post_type")
  createdAt    DateTime @default(now()) @map("created_at")

  @@index([createdAt])
  @@map("llm_usage_logs")
}

model ContentPost {
  id            String    @id @default(uuid())
  postType      String    @map("post_type")
  channel       String
  generatedText String    @map("generated_text")
  status        String    @default("pending")
  scheduledDate DateTime  @map("scheduled_date")
  postedAt      DateTime? @map("posted_at")
  postNow       Boolean   @default(false) @map("post_now")
  error         String?
  createdAt     DateTime  @default(now()) @map("created_at")

  @@index([status])
  @@index([scheduledDate])
  @@map("content_posts")
}

/// Configuration for the AI chat assistant — single row, upserted on save.
model AiChatSettings {
  id                   String   @id @default(cuid())
  model                String   @default("deepseek-chat")
  contextHours         Int      @default(48) @map("context_hours")
  maxVenues            Int      @default(20) @map("max_venues")
  maxClubs             Int      @default(20) @map("max_clubs")
  maxCostPerMessageUsd Float    @default(0.05) @map("max_cost_per_message_usd")
  dailyCostAlertUsd    Float    @default(5.00) @map("daily_cost_alert_usd")
  playerFacingEnabled  Boolean  @default(false) @map("player_facing_enabled")
  updatedAt            DateTime @updatedAt @map("updated_at")
  updatedBy            String?  @map("updated_by")

  @@map("ai_chat_settings")
}

/// Chat logs for the AI assistant (admin testing and player-facing).
model AiAssistantLog {
  id               String   @id @default(cuid())
  sessionId        String   @map("session_id")
  role             String
  content          String
  inputTokens      Int?     @map("input_tokens")
  outputTokens     Int?     @map("output_tokens")
  estimatedCostUsd Float?   @map("estimated_cost_usd")
  /// JSON snapshot of the context payload used for this conversation session (stored on first message only).
  contextSnapshot  String?  @map("context_snapshot")
  /// "admin" or "player"
  source           String   @default("admin")
  createdAt        DateTime @default(now()) @map("created_at")

  @@index([sessionId])
  @@index([createdAt])
  @@index([source])
  @@map("ai_assistant_logs")
}

/// Push notification delivery log for throttling and analytics.
model NotificationSent {
  id          Int      @id @default(autoincrement())
  recipientId String   @map("recipient_id")
  senderId    String?  @map("sender_id")
  type        String
  sentAt      DateTime @default(now()) @map("sent_at")

  recipient   PlayerProfile @relation("recipient", fields: [recipientId], references: [id], onDelete: Cascade)
  sender      PlayerProfile? @relation("sender", fields: [senderId], references: [id], onDelete: SetNull)

  @@index([recipientId, type, sentAt])
  @@map("notifications_sent")
}

model Kudos {
  id           Int      @id @default(autoincrement())
  fromPlayerId String   @map("from_player_id")
  toPlayerId   BigInt   @map("to_player_id")
  type         String
  feedItemId   String?  @map("feed_item_id")
  createdAt    DateTime @default(now()) @map("created_at")

  @@unique([fromPlayerId, toPlayerId, type, feedItemId])
  @@index([toPlayerId, type])
  @@index([fromPlayerId, createdAt])
  @@map("kudos")
}

/// Persisted feed item for a user's feed — survives unfollow so history is retained.
model FeedItem {
  id           String   @id
  profileId    String   @map("profile_id")
  type         String
  playerUserId String?  @map("player_user_id")
  payload      Json
  timestamp    DateTime
  createdAt    DateTime @default(now()) @map("created_at")

  profile      PlayerProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@index([profileId, timestamp(sort: Desc)])
  @@index([profileId, type])
  @@map("feed_items")
}

model PlayIntent {
  id          String        @id @default(cuid())
  profileId   String        @unique @map("profile_id")
  timeSlot    String        @map("time_slot")
  date        String
  zaloNumber  String?       @map("zalo_number")
  expiresAt   DateTime      @map("expires_at")
  createdAt   DateTime      @default(now()) @map("created_at")

  profile     PlayerProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@index([expiresAt])
  @@map("play_intents")
}

model Block {
  id          String        @id @default(cuid())
  blockerId   String        @map("blocker_id")
  blockedId   String        @map("blocked_id")
  createdAt   DateTime      @default(now()) @map("created_at")

  blocker     PlayerProfile @relation("Blocker", fields: [blockerId], references: [id], onDelete: Cascade)
  blocked     PlayerProfile @relation("Blocked", fields: [blockedId], references: [id], onDelete: Cascade)

  @@unique([blockerId, blockedId])
  @@index([blockerId])
  @@index([blockedId])
  @@map("blocks")
}

model Report {
  id           String        @id @default(cuid())
  reporterId   String        @map("reporter_id")
  reportedId   String        @map("reported_id")
  reason       String
  detail       String?
  status       String        @default("pending")
  createdAt    DateTime      @default(now()) @map("created_at")

  reporter     PlayerProfile @relation("Reporter", fields: [reporterId], references: [id], onDelete: Cascade)
  reported     PlayerProfile @relation("Reported", fields: [reportedId], references: [id], onDelete: Cascade)

  @@unique([reporterId, reportedId])
  @@index([reportedId])
  @@index([status])
  @@map("reports")
}

/// Aggregated DUPR participation for a session row (keyed by sessions.id).
model SessionDuprStat {
  sessionId              Int      @id @map("session_id")
  scrapedDate            String   @map("scraped_date")
  totalConfirmed         Int      @default(0) @map("total_confirmed")
  playersWithDupr        Int      @default(0) @map("players_with_dupr")
  duprParticipationPct   Decimal  @default(0) @map("dupr_participation_pct") @db.Decimal(5, 2)
  avgDuprSingles         Decimal? @map("avg_dupr_singles") @db.Decimal(5, 3)
  avgDuprDoubles         Decimal? @map("avg_dupr_doubles") @db.Decimal(5, 3)
  /// % of confirmed players who have attended this club ≥3 times in the past 60 days (null = not yet computed).
  returningPlayerPct     Decimal? @map("returning_player_pct") @db.Decimal(5, 2)
  updatedAt              DateTime @updatedAt @map("updated_at")

  session Session @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@map("session_dupr_stats")
}

model Squad {
  id           String        @id @default(uuid())
  name         String
  emoji        String
  color        String
  isPublic     Boolean       @default(true) @map("is_public")
  showDupr     Boolean       @default(true) @map("show_dupr")
  appSlug      String        @default("squadd") @map("app_slug")
  founderId    String        @map("founder_id")
  totalXp      Int           @default(0) @map("total_xp")
  level        Int           @default(1)
  city         String        @default("hcm")
  streakDays   Int           @default(0) @map("streak_days")
  streakLastUpdated DateTime? @map("streak_last_updated") @db.Date
  latitude     Float?        @map("latitude")
  longitude    Float?        @map("longitude")
  createdAt    DateTime      @default(now()) @map("created_at")
  disbandedAt  DateTime?     @map("disbanded_at")

  founder      PlayerProfile @relation("SquadFounder", fields: [founderId], references: [id])
  members      SquadMember[]
  code         SquadCode?
  invites      SquadInvite[]
  chests       SquadChest[]
  xpLog        SquadXpLog[]
  pods         Pod[]
  radarSessions     RadarSession[]
  cardBattlesInit   CardBattle[]      @relation("InitiatingSquad")
  cardBattlesRival  CardBattle[]      @relation("RivalSquad")
  venueInfTotals    VenueInfTotal[]
  squadCardState    SquadCardState?
  squadAlerts       SquadAlert[]

  @@index([founderId])
  @@index([latitude, longitude])
  @@map("squads")
}

model SquadMember {
  id        Int           @id @default(autoincrement())
  squadId   String        @map("squad_id")
  profileId String        @map("profile_id")
  role      String        @default("member")
  joinedAt  DateTime      @default(now()) @map("joined_at")
  leftAt    DateTime?     @map("left_at")

  squad     Squad         @relation(fields: [squadId], references: [id], onDelete: Cascade)
  profile   PlayerProfile @relation(fields: [profileId], references: [id])

  @@unique([squadId, profileId])
  @@index([profileId])
  @@map("squad_members")
}

model SquadCode {
  id        Int      @id @default(autoincrement())
  squadId   String   @unique @map("squad_id")
  code      String   @unique
  appSlug   String   @default("squadd") @map("app_slug")
  createdAt DateTime @default(now()) @map("created_at")

  squad     Squad    @relation(fields: [squadId], references: [id], onDelete: Cascade)

  @@map("squad_codes")
}

model SquadInvite {
  id             Int       @id @default(autoincrement())
  /// Nullable for solo Gang invites (no clubhouse yet). Set when the Gang joins a squad.
  squadId        String?   @map("squad_id")
  inviterId      String    @map("inviter_id")
  inviteeId      String?   @map("invitee_id")
  inviteeName    String?   @map("invitee_name")
  inviteChannel  String    @default("push") @map("invite_channel")
  status         String    @default("pending")
  podId          String?   @map("pod_id")
  /// 'gang' = friend-to-friend Gang invite (default); 'clubhouse' = admin/squad-level invite
  inviteType     String    @default("gang") @map("invite_type")
  createdAt      DateTime  @default(now()) @map("created_at")
  resolvedAt     DateTime? @map("resolved_at")
  lastResentAt   DateTime? @map("last_resent_at")

  squad          Squad?        @relation(fields: [squadId], references: [id], onDelete: Cascade)
  inviter        PlayerProfile @relation("InviterInvites", fields: [inviterId], references: [id])
  pod            Pod?          @relation(fields: [podId], references: [id])

  @@index([squadId])
  @@index([inviteeId])
  @@index([podId])
  @@map("squad_invites")
}

model SquadChest {
  id          String              @id @default(uuid())
  squadId     String              @map("squad_id")
  earnerId    String              @map("earner_id")
  sessionId   Int?                @map("session_id")
  source      String              @default("checkin")
  venueName   String?             @map("venue_name")
  checkinDate DateTime?           @map("checkin_date") @db.Date
  createdAt   DateTime            @default(now()) @map("created_at")
  expiresAt   DateTime            @map("expires_at")

  squad       Squad               @relation(fields: [squadId], references: [id], onDelete: Cascade)
  earner      PlayerProfile       @relation("ChestEarner", fields: [earnerId], references: [id])
  openings    SquadChestOpening[]

  @@unique([squadId, earnerId, checkinDate])
  @@index([squadId])
  @@index([expiresAt])
  @@map("squad_chests")
}

model SquadChestOpening {
  id           Int           @id @default(autoincrement())
  chestId      String        @map("chest_id")
  profileId    String        @map("profile_id")
  status       String        @default("pending")
  tappedAt     DateTime?     @map("tapped_at")
  unlocksAt    DateTime?     @map("unlocks_at")
  openedAt     DateTime?     @map("opened_at")
  kudosAwarded Int?          @map("kudos_awarded")
  xpAwarded    Int?          @map("xp_awarded")

  chest        SquadChest    @relation(fields: [chestId], references: [id], onDelete: Cascade)
  profile      PlayerProfile @relation(fields: [profileId], references: [id])

  @@unique([chestId, profileId])
  @@index([chestId])
  @@index([profileId])
  @@index([unlocksAt])
  @@map("squad_chest_openings")
}

model SquadXpLog {
  id        Int           @id @default(autoincrement())
  squadId   String        @map("squad_id")
  profileId String?       @map("profile_id")
  source    String
  xpAmount  Int           @map("xp_amount")
  createdAt DateTime      @default(now()) @map("created_at")

  squad     Squad         @relation(fields: [squadId], references: [id], onDelete: Cascade)

  @@index([squadId])
  @@index([createdAt])
  @@map("squad_xp_log")
}

model SquadWaitlist {
  id          Int      @id @default(autoincrement())
  squadName   String   @map("squad_name")
  emoji       String
  country     String
  city        String
  friendCount Int      @map("friend_count")
  profileId   String?  @map("profile_id")
  playerName  String?  @map("player_name")
  playerEmail String?  @map("player_email")
  playerDupr  Decimal? @map("player_dupr") @db.Decimal(5, 3)
  createdAt   DateTime @default(now()) @map("created_at")

  @@map("squad_waitlist")
}

// ── Pods, Tokens & Brands ────────────────────────────────────────────────────

model Pod {
  id          String    @id @default(uuid())
  /// Nullable — a solo Gang created during onboarding has no clubhouse yet.
  /// Set when the Gang joins or founds a Squad (clubhouse).
  squadId     String?   @map("squad_id")
  name        String
  emoji       String
  founderId   String    @map("founder_id")
  createdAt   DateTime  @default(now()) @map("created_at")
  disbandedAt DateTime? @map("disbanded_at")

  squad       Squad?        @relation(fields: [squadId], references: [id])
  founder     PlayerProfile @relation("PodFounder", fields: [founderId], references: [id])
  members     PodMember[]
  invites     SquadInvite[]

  @@index([squadId])
  @@index([founderId])
  @@map("pods")
}

model PodMember {
  id        Int       @id @default(autoincrement())
  podId     String    @map("pod_id")
  profileId String    @map("profile_id")
  joinedAt  DateTime  @default(now()) @map("joined_at")
  leftAt    DateTime? @map("left_at")

  pod       Pod           @relation(fields: [podId], references: [id])
  profile   PlayerProfile @relation(fields: [profileId], references: [id])

  @@unique([podId, profileId])
  @@index([profileId])
  @@map("pod_members")
}

/// One paddle brand record per player. Created lazily on first selection.
model PlayerBrand {
  id            String   @id @default(uuid())
  profileId     String   @unique @map("profile_id")
  brand         String
  supportLevel  Int      @default(1) @map("support_level")
  brandXp       Int      @default(0) @map("brand_xp")
  selectedAt    DateTime @default(now()) @map("selected_at")
  switchedCount Int      @default(0) @map("switched_count")

  profile       PlayerProfile @relation(fields: [profileId], references: [id])

  @@map("player_brands")
}

/// Running personal token balance. One row per player, lazily created.
model PlayerWallet {
  id           String   @id @default(uuid())
  profileId    String   @unique @map("profile_id")
  clubTokens   Int      @default(0) @map("club_tokens")
  brandTokens  Int      @default(0) @map("brand_tokens")
  updatedAt    DateTime @updatedAt @map("updated_at")

  profile      PlayerProfile @relation(fields: [profileId], references: [id])

  @@map("player_wallets")
}

/// Audit log for every token movement.
model TokenLedger {
  id        Int      @id @default(autoincrement())
  profileId String   @map("profile_id")
  tokenType String   @map("token_type")
  delta     Int
  reason    String
  squadId   String?  @map("squad_id")
  createdAt DateTime @default(now()) @map("created_at")

  @@index([profileId, createdAt])
  @@map("token_ledger")
}

// ── Squad Conquest (Phase 4) ─────────────────────────────────────────────────

model RadarSession {
  id                    String    @id @default(uuid())
  squadId               String    @map("squad_id")
  playerId              String    @map("player_id")
  venueId               Int       @map("venue_id")
  startedAt             DateTime  @default(now()) @map("started_at")
  autoEndsAt            DateTime  @map("auto_ends_at")
  stoppedAt             DateTime? @map("stopped_at")
  isClashActive         Boolean   @default(false) @map("is_clash_active")
  clashPartnerSquadId   String?   @map("clash_partner_squad_id")
  infBase               Int?      @map("inf_base")
  infFinal              Int?      @map("inf_final")
  state                 String    @default("active")

  squad                 Squad           @relation(fields: [squadId], references: [id])
  venue                 Venue           @relation(fields: [venueId], references: [id])
  player                PlayerProfile   @relation(fields: [playerId], references: [id])

  @@index([venueId, state])
  @@index([squadId, state])
  @@index([playerId, state])
  @@index([autoEndsAt, state])
  @@map("radar_sessions")
}

model CardBattle {
  id                          String    @id @default(uuid())
  venueId                     Int       @map("venue_id")
  initiatingSquadId           String    @map("initiating_squad_id")
  rivalSquadId                String    @map("rival_squad_id")
  initiatingCardPower         Int       @map("initiating_card_power")
  rivalCardPower              Int       @map("rival_card_power")
  winnerSquadId               String?   @map("winner_squad_id")
  initiatedAt                 DateTime  @default(now()) @map("initiated_at")
  revealAt                    DateTime  @map("reveal_at")
  counterAttackWindowEndsAt   DateTime  @map("counter_attack_window_ends_at")
  battleNumber                Int       @default(1) @map("battle_number")
  isCounterAttack             Boolean   @default(false) @map("is_counter_attack")
  parentBattleId              String?   @map("parent_battle_id")

  initiatingSquad             Squad     @relation("InitiatingSquad", fields: [initiatingSquadId], references: [id])
  rivalSquad                  Squad     @relation("RivalSquad", fields: [rivalSquadId], references: [id])
  venue                       Venue     @relation(fields: [venueId], references: [id])

  @@index([venueId, initiatedAt])
  @@index([initiatingSquadId])
  @@index([rivalSquadId])
  @@map("card_battles")
}

model VenueInfTotal {
  squadId         String    @map("squad_id")
  venueId         Int       @map("venue_id")
  totalInf        Int       @default(0) @map("total_inf")
  lastUpdatedAt   DateTime  @default(now()) @map("last_updated_at")

  squad           Squad     @relation(fields: [squadId], references: [id])
  venue           Venue     @relation(fields: [venueId], references: [id])

  @@id([squadId, venueId])
  @@index([venueId, totalInf(sort: Desc)])
  @@map("venue_inf_totals")
}

model VenuePulseCooldown {
  playerId          String    @map("player_id")
  venueId           Int       @map("venue_id")
  lastPulseAt       DateTime  @map("last_pulse_at")
  cooldownEndsAt    DateTime  @map("cooldown_ends_at")

  player            PlayerProfile   @relation(fields: [playerId], references: [id])
  venue             Venue           @relation(fields: [venueId], references: [id])

  @@id([playerId, venueId])
  @@map("venue_pulse_cooldowns")
}

model SquadCardState {
  squadId                 String    @id @map("squad_id")
  cardPowerInf            Int       @map("card_power_inf")
  cardLevelMultiplier     Decimal   @map("card_level_multiplier") @db.Decimal(4, 2)
  venuesOwnedCount        Int       @default(0) @map("venues_owned_count")
  activeMembersThisWeek   Int       @default(0) @map("active_members_this_week")
  lastComputedAt          DateTime  @default(now()) @map("last_computed_at")

  squad                   Squad     @relation(fields: [squadId], references: [id])

  @@map("squad_card_state")
}

model SquadAlert {
  id                  String    @id @default(uuid())
  squadId             String    @map("squad_id")
  recipientProfileId  String    @map("recipient_profile_id")
  type                String
  title               String
  body                String
  payload             Json?
  readAt              DateTime? @map("read_at")
  createdAt           DateTime  @default(now()) @map("created_at")

  squad               Squad           @relation(fields: [squadId], references: [id])
  recipient           PlayerProfile   @relation(fields: [recipientProfileId], references: [id])

  @@index([recipientProfileId, readAt])
  @@index([squadId, createdAt])
  @@map("squad_alerts")
}

// ── Club Sessions ─────────────────────────────────────────────────────────────
// Names use AppClub / ClubSession / ClubSessionBooking to avoid collision with:
//   Club (scraped Reclub entity, clubs table)
//   Session (scraped Reclub entity, sessions table)
//   AuthSession (NextAuth model)

/// App-managed pickleball club. One club per creator (creatorId is unique).
/// Multiple managers are supported via AppClubManager.
model AppClub {
  id                    String   @id @default(uuid())
  name                  String
  icon                  String?
  sportId               Int?     @map("sport_id")
  /// "public" | "private"
  privacy               String   @default("public")
  level                 String?
  /// When true, booking a session auto-enrolls the player as a member with no separate step.
  autoApproveNewMembers Boolean  @default(true) @map("auto_approve_new_members")
  /// One club per creator — enforced as @unique. A player can found only one club.
  creatorId             String   @unique @map("creator_id")
  createdAt             DateTime @default(now()) @map("created_at")
  updatedAt             DateTime @updatedAt @map("updated_at")

  creator   PlayerProfile    @relation("AppClubCreator", fields: [creatorId], references: [id])
  managers  AppClubManager[]
  sessions  ClubSession[]
  members   AppClubMember[]

  @@index([privacy])
  @@map("app_clubs")
}

/// Multi-manager support for AppClub. Creator row is seeded automatically on club creation.
/// Authorization: any row in this table grants equal rights to edit the club and manage its sessions.
model AppClubManager {
  id              String   @id @default(uuid())
  appClubId       String   @map("app_club_id")
  playerProfileId String   @map("player_profile_id")
  /// "creator" | "manager"
  role            String   @default("manager")
  addedAt         DateTime @default(now()) @map("added_at")
  addedById       String   @map("added_by_id")

  appClub   AppClub       @relation(fields: [appClubId], references: [id], onDelete: Cascade)
  profile   PlayerProfile @relation("ManagerProfile", fields: [playerProfileId], references: [id])
  addedBy   PlayerProfile @relation("ManagerAddedBy", fields: [addedById], references: [id])

  @@unique([appClubId, playerProfileId])
  @@index([playerProfileId])
  @@map("app_club_managers")
}

/// Binary club membership for players. Joining is a one-tap action with no approval state machine.
model AppClubMember {
  id              String   @id @default(uuid())
  appClubId       String   @map("app_club_id")
  playerProfileId String   @map("player_profile_id")
  joinedAt        DateTime @default(now()) @map("joined_at")

  appClub  AppClub       @relation(fields: [appClubId], references: [id], onDelete: Cascade)
  profile  PlayerProfile @relation(fields: [playerProfileId], references: [id])

  @@unique([appClubId, playerProfileId])
  @@index([playerProfileId])
  @@map("app_club_members")
}

/// App-managed session created by a host under an AppClub.
/// startTime/endTime are real DateTime fields (unlike scraped Session which uses String).
model ClubSession {
  id             String    @id @default(uuid())
  appClubId      String    @map("app_club_id")
  hostId         String    @map("host_id")
  sportId        Int?      @map("sport_id")
  /// "social" | "round_robin" | "singles"
  format         String
  name           String
  startTime      DateTime  @map("start_time")
  endTime        DateTime  @map("end_time")
  durationMin    Int       @map("duration_min")
  venueId        Int?      @map("venue_id")
  /// True when venue is not yet determined (venue shown as "To be determined")
  venuePending   Boolean   @default(false) @map("venue_pending")
  /// Soft target, not a hard cap. Host may confirm past this number.
  maxPlayers     Int       @map("max_players")
  requiresApproval Boolean @default(false) @map("requires_approval")
  /// "public" | "private"
  privacy        String    @default("public")
  feeAmount      Decimal?  @map("fee_amount") @db.Decimal(10, 2)
  feeCurrency    String?   @map("fee_currency")
  skillLevelMin  Decimal?  @map("skill_level_min") @db.Decimal(5, 3)
  skillLevelMax  Decimal?  @map("skill_level_max") @db.Decimal(5, 3)
  /// "host_and_play" | "host_only"
  hostRole       String    @default("host_and_play") @map("host_role")
  notes          String?
  /// "draft" | "published" | "cancelled"
  lifecycleState String    @default("draft") @map("lifecycle_state")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  appClub  AppClub              @relation(fields: [appClubId], references: [id])
  host     PlayerProfile        @relation("SessionHost", fields: [hostId], references: [id])
  venue    Venue?               @relation(fields: [venueId], references: [id])
  bookings ClubSessionBooking[]

  @@index([appClubId, startTime])
  @@index([lifecycleState, startTime])
  @@index([venueId])
  @@map("club_sessions")
}

/// Player booking for a ClubSession. Keyed off PlayerProfile (same identity table as Squadd).
/// attendanceStatus uses "checked_in" (not "checkin") to stay distinct from SquadChest.source="checkin".
model ClubSessionBooking {
  id              String    @id @default(uuid())
  playerProfileId String    @map("player_profile_id")
  clubSessionId   String    @map("club_session_id")
  /// "requested" | "confirmed" | "waiting_list" | "declined"
  status          String    @default("requested")
  /// Host-controlled manual payment flag. Only meaningful on confirmed bookings.
  paidStatus      Boolean   @default(false) @map("paid_status")
  /// "unmarked" | "checked_in" | "no_show" — host-controlled, day-of, confirmed bookings only.
  attendanceStatus String   @default("unmarked") @map("attendance_status")
  requestedAt     DateTime  @default(now()) @map("requested_at")
  decidedAt       DateTime? @map("decided_at")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  player      PlayerProfile @relation(fields: [playerProfileId], references: [id])
  clubSession ClubSession   @relation(fields: [clubSessionId], references: [id], onDelete: Cascade)

  @@unique([playerProfileId, clubSessionId])
  @@index([clubSessionId, status])
  @@index([playerProfileId])
  @@map("club_session_bookings")
}

