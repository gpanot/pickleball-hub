                     BuildableName = "SQUADD.app"
                     BlueprintName = "SQUADD"
                     ReferencedContainer = "container:SQUADD.xcodeproj">
                  </BuildableReference>
               </EnvironmentBuildable>
            </ActionContent>
         </ExecutionAction>
      </PreActions>
      <BuildActionEntries>
         <BuildActionEntry
            buildForTesting = "YES"
            buildForRunning = "YES"
