      <PreActions>
         <ExecutionAction
            ActionType = "Xcode.IDEStandardExecutionActionsCore.ExecutionActionType.ShellScriptExecutionAction">
            <ActionContent
               title = "Patch Pods for spaces in path"
               scriptText = "cd &quot;$SRCROOT/..&quot; &amp;&amp; sh scripts/patch-pods-space.sh 2&gt;&amp;1 || true&#10;">
               <EnvironmentBuildable>
                  <BuildableReference
                     BuildableIdentifier = "primary"
