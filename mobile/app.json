{
  "expo": {
    "name": "SQUADD",
    "slug": "the-hub",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "cover",
      "backgroundColor": "#0a0a0a"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.squadd.thehub.app",
      "appleTeamId": "F8VE3HCR27",
      "googleServicesFile": "./GoogleService-Info.plist",
      "usesAppleSignIn": true,
      "infoPlist": {
        "NSUserNotificationsUsageDescription": "Get notified when you receive kudos, when friends are playing, or when someone follows you.",
        "CFBundleURLTypes": [
          {
            "CFBundleURLSchemes": [
              "com.squadd.thehub.app"
            ]
          },
          {
            "CFBundleTypeRole": "Editor",
            "CFBundleURLSchemes": [
              "com.googleusercontent.apps.140906288105-oa9csuarionhlcsksjjeakcrqob2auvn"
            ]
          }
        ]
      }
    },
    "newArchEnabled": true,
    "android": {
      "package": "com.squadd.thehub.app",
      "adaptiveIcon": {
        "foregroundImage": "./assets/icon.png",
        "backgroundColor": "#0a0a0a"
      },
      "googleServicesFile": "./google-services.json",
      "permissions": [
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION"
      ]
    },
    "scheme": "com.squadd.thehub.app",
    "assetBundlePatterns": [
      "assets/**/*"
    ],
    "plugins": [
      "@react-native-firebase/app",
      "expo-asset",
      [
        "expo-font",
        {
          "fonts": [
            "./assets/fonts/Bangers_400Regular.ttf"
          ]
        }
      ],
      "expo-secure-store",
      "@react-native-google-signin/google-signin",
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Allow SQUADD to show distances to sessions near you."
        }
      ],
      [
        "expo-notifications",
        {
          "color": "#f5a623",
          "defaultChannel": "default"
        }
      ]
    ],
    "updates": {
      "enabled": false
    }
  }
}
